generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model campaigns {
  id         Int                   @id @default(autoincrement())
  name       String                @db.VarChar(255)
  difficulty campaigns_difficulty? @default(medium)
  created_at DateTime?             @default(now()) @db.Timestamp(0)
}

model link_events {
  id               Int                     @id @default(autoincrement())
  phishing_link_id Int
  event_type       link_events_event_type? @default(click)
  ip_address       String?                 @db.VarChar(255)
  user_agent       String?                 @db.Text
  created_at       DateTime?               @default(now()) @db.Timestamp(0)

  @@index([phishing_link_id], map: "phishing_link_id")
}

model phishing_links {
  id           Int       @id @default(autoincrement())
  campaign_id  Int
  recipient_id Int
  tracking_id  String    @unique(map: "tracking_id") @db.VarChar(48)
  created_at   DateTime? @default(now()) @db.Timestamp(0)

  @@unique([campaign_id, recipient_id], map: "unique_campaign_recipient")
  @@index([recipient_id], map: "recipient_id")
}

model recipients {
  id         Int       @id @default(autoincrement())
  firstName  String?   @map("first_name") @db.VarChar(255)
  lastName   String?   @map("last_name") @db.VarChar(255)
  email      String?   @db.VarChar(255)
  department String?   @db.VarChar(255)
  jobTitle   String?   @map("job_title") @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(0)
}

model users {
  id         Int       @id @default(autoincrement())
  email      String    @unique(map: "email")
  password   String    @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  role       String?   @db.VarChar(20)
}

enum campaigns_difficulty {
  low
  medium
  high
}

enum link_events_event_type {
  click
}
