generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model campaigns {
  id             Int             @id @default(autoincrement())
  name           String
  difficulty     String          @default("medium")
  created_at     DateTime        @default(now())
  phishing_links phishing_links[]
}

model link_events {
  id               Int            @id @default(autoincrement())
  phishing_link_id Int
  event_type       String         @default("click")
  ip_address       String?
  user_agent       String?
  created_at       DateTime       @default(now())
  phishing_link    phishing_links @relation(fields: [phishing_link_id], references: [id], onDelete: Cascade)

  @@index([phishing_link_id])
}

model phishing_links {
  id          Int         @id @default(autoincrement())
  campaign_id Int
  recipient_id Int
  tracking_id String      @unique
  created_at  DateTime    @default(now())
  campaign    campaigns   @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  recipient   recipients  @relation(fields: [recipient_id], references: [id], onDelete: Cascade)
  link_events link_events[]

  @@unique([campaign_id, recipient_id])
  @@index([recipient_id])
}

model recipients {
  id              Int              @id @default(autoincrement())
  firstName       String?
  lastName        String?
  email           String?
  phishing_links  phishing_links[]
}

model users {
  id         Int     @id @default(autoincrement())
  email      String  @unique
  password   String
  created_at DateTime @default(now())
  roles      String?
  role       String  @default("admin")
}
