generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model campaigns {
  id         Int                   @id @default(autoincrement())
  name       String                @db.VarChar(255)
  difficulty campaigns_difficulty? @default(medium)
  created_at DateTime?             @default(now()) @db.Timestamp(0)
}

model link_events {
  id               Int                     @id @default(autoincrement())
  phishing_link_id Int
  event_type       link_events_event_type? @default(click)
  ip_address       String?                 @db.VarChar(255)
  user_agent       String?                 @db.Text
  created_at       DateTime?               @default(now()) @db.Timestamp(0)

  @@index([phishing_link_id], map: "phishing_link_id")
}

model phishing_links {
  id           Int       @id @default(autoincrement())
  campaign_id  Int
  recipient_id Int
  tracking_id  String    @unique(map: "tracking_id") @db.VarChar(48)
  created_at   DateTime? @default(now()) @db.Timestamp(0)

  @@unique([campaign_id, recipient_id], map: "unique_campaign_recipient")
  @@index([recipient_id], map: "recipient_id")
}

model recipients {
  id        Int     @id @default(autoincrement())
  firstName String? @db.VarChar(255)
  lastName  String? @db.VarChar(255)
  email     String? @db.VarChar(255)
}

model users {
  id         Int          @id @default(autoincrement())
  email      String       @unique(map: "email")
  password   String       @db.VarChar(255)
  created_at DateTime?    @default(now()) @db.Timestamp(0)
  roles      String?      @db.VarChar(255)
  user_roles user_roles[]
}

model permissions {
  id               Int                @id @default(autoincrement())
  name             String             @unique(map: "name") @db.VarChar(100)
  role_permissions role_permissions[]
}

model role_permissions {
  role_id       Int
  permission_id Int
  
  roles       roles       @relation(fields: [role_id], references: [id], map: "fk_role_permissions_role")
  permission  permissions @relation(fields: [permission_id], references: [id], map: "fk_role_permissions_permission")

  @@id([role_id, permission_id])
  @@index([permission_id], map: "fk_role_permissions_permission")
}

model roles {
  id               Int                @id @default(autoincrement())
  name             String             @unique(map: "name") @db.VarChar(50)
  user_roles       user_roles[]  // relation to junction table
  role_permissions role_permissions[]
}

model user_roles {
  user_id Int
  role_id Int
  
  users users @relation(fields: [user_id], references: [id], map: "fk_user_roles_user")
  role  roles @relation(fields: [role_id], references: [id], map: "fk_user_roles_role")

  @@id([user_id, role_id])
  @@index([role_id], map: "fk_user_roles_role")
}

enum campaigns_difficulty {
  low
  medium
  high
}

enum link_events_event_type {
  click
}
